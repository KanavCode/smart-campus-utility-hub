# =====================================================================
# Smart Campus Backend - Environment Variables Example
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# =====================================================================

# -----------------------------------------------
# Server
# -----------------------------------------------
NODE_ENV=development
PORT=5000

# -----------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_campus_unified
DB_USER=postgres
DB_PASSWORD=replace_with_a_strong_database_password

# Advanced pool tuning (optional)
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# -----------------------------------------------
# Authentication
# -----------------------------------------------
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------
# CORS (production only)
# Comma-separated list of allowed origins
# -----------------------------------------------
CORS_ORIGINS=https://your-frontend-domain.com

# -----------------------------------------------
# Rate Limiting
# -----------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# -----------------------------------------------
# Logging
# -----------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------
# Email Service (Nodemailer)
# -----------------------------------------------
# Development: Use Mailtrap (https://mailtrap.io)
# Production: Use your email service (Gmail, SendGrid, etc.)

NODE_ENV=development
EMAIL_FROM=noreply@smartcampus.edu
FRONTEND_URL=http://localhost:5173

# Mailtrap Configuration (Development)
MAILTRAP_HOST=live.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your_mailtrap_user
MAILTRAP_PASSWORD=your_mailtrap_password

# Gmail Configuration (Alternative)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# Password Reset Token Expiry (in minutes)
PASSWORD_RESET_EXPIRY_MINUTES=15
